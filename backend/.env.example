# Copy to .env for local dev, or set these in Render's Environment tab.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=https://your-netlify-site.netlify.app

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=glowstate2026

# PayPal REST API (Orders v2) — required for the real PayPal Checkout button.
# Create an app at https://developer.paypal.com/dashboard/applications
# (use the account tied to Glowstatepeps@hotmail.com) and paste its
# Client ID + Secret here. Client ID is also stored in the PaymentDetails
# row (Django admin) so the frontend can load the PayPal JS SDK.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Optional SMTP (leave EMAIL_ENABLED=False to skip real email sending —
# order/status notifications still get logged in the Activity feed either way)
EMAIL_ENABLED=False
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=True
SMTP_FROM=no-reply@glowstatepeptides.com
ADMIN_NOTIFICATION_EMAIL=
